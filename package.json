{
  "name": "manwah-pos-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:frontend": "npm run build -w frontend",
    "start:backend": "npm start -w backend",
    "dev": "npx concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "start": "npm start -w backend",
    "render-build:frontend": "npm install && npm run build -w frontend",
    "render-start:backend": "npm install && npm start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
